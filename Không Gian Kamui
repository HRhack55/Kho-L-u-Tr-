-- NGƯỜI CHƠI & CÔNG CỤ
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- GIAO DIỆN (UI)
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Parent = screenGui
button.Position = UDim2.new(0, 10, 0.5, -25)
button.Size = UDim2.new(0, 200, 0, 50)
button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
button.Text = "Kamui Dimension"
button.TextColor3 = Color3.fromRGB(0, 0, 0)
button.Font = Enum.Font.SourceSansBold
button.TextSize = 20

-- CÀI ĐẶT
local MODEL_ID = 6164248822                             -- ID model Roblox
local TARGET_CFRAME = CFrame.new(104, -349, -571)       -- Vị trí teleport (X, Y, Z)

-- TRẠNG THÁI
local model = nil
local savedCFrame = nil
local teleported = false
local debounce = false

-- LẤY NHÂN VẬT
local function getCharacter()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")
	return char, hrp
end

-- DỊCH CHUYỂN
local function teleport(cf)
	local _, hrp = getCharacter()

	hrp.AssemblyLinearVelocity = Vector3.zero
	hrp.AssemblyAngularVelocity = Vector3.zero
	hrp.CFrame = cf
end

-- TẢI MODEL
local function loadModel()
	local success, result = pcall(function()
		return game:GetObjects("rbxassetid://" .. MODEL_ID)
	end)

	if success and result and result[1] then
		local m = result[1]
		m.Parent = workspace
		return m
	end

	warn("Không load được model")
	return nil
end

model = loadModel()

-- NÚT LOGIC
button.MouseButton1Click:Connect(function()
	if debounce then return end
	debounce = true

	local _, hrp = getCharacter()

	if not teleported then
		-- Lần 1: lưu vị trí + teleport tới điểm mục tiêu
		savedCFrame = hrp.CFrame
		teleport(TARGET_CFRAME)
		teleported = true
	else
		-- Lần 2: quay lại vị trí cũ
		if savedCFrame then
			teleport(savedCFrame)
		end
		teleported = false
	end

	task.wait(0.2)
	debounce = false
end)

































